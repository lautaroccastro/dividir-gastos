# Copiar desde Supabase → Project Settings → API (mismo proyecto)
NEXT_PUBLIC_SUPABASE_URL=
# Clave pública del cliente: Publishable (sb_publishable_...) recomendada, o anon legacy (eyJ...). No uses la secret/service_role.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor (nunca NEXT_PUBLIC_*). Necesaria para cargar datos del enlace público /share/[token].
# Project Settings → API → service_role (secreta).
SUPABASE_SERVICE_ROLE_KEY=
